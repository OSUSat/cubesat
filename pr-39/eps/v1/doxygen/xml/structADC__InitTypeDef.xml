        <type><ref refid="structADC__OversamplingTypeDef" kindref="compound">ADC_OversamplingTypeDef</ref></type>
        <definition>ADC_OversamplingTypeDef ADC_InitTypeDef::Oversampling</definition>
        <argsstring></argsstring>
        <name>Oversampling</name>
        <qualifiedname>ADC_InitTypeDef::Oversampling</qualifiedname>
        <briefdescription>
