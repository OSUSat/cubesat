</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">profile</parametername>
</parameternamelist>
<parameterdescription>
<para>The target profile to disable.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>POWER_PROFILE_SUCCESS</parametername>
</parameternamelist>
<parameterdescription>
