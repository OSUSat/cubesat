        <name>osusat_slog_init</name>
        <param>
          <type><ref refid="structosusat__ring__buffer__t" kindref="compound">osusat_ring_buffer_t</ref> *</type>
          <declname>log_buf</declname>
        </param>
        <param>
          <type><ref refid="group__osusat__slog__types_1ga39b7ea30f55831ceddb5ab6bc8f316c3" kindref="member">osusat_slog_timestamp_fn_t</ref></type>
