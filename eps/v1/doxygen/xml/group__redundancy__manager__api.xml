        <type>void</type>
        <definition>void redundancy_manager_init</definition>
        <argsstring>(redundancy_manager_t *manager)</argsstring>
        <name>redundancy_manager_init</name>
        <param>
          <type><ref refid="structredundancy__manager__t" kindref="compound">redundancy_manager_t</ref> *</type>
          <declname>manager</declname>
