        <type>void</type>
        <definition>void rail_controller_init</definition>
        <argsstring>(rail_controller_t *manager)</argsstring>
        <name>rail_controller_init</name>
        <param>
          <type><ref refid="structrail__controller__t" kindref="compound">rail_controller_t</ref> *</type>
          <declname>manager</declname>
        </param>
        <briefdescription>
<para>Initialize the Rail Controller hardware. </para>
        </briefdescription>
        <detaileddescription>
<para>Configures GPIO pins for load switches as outputs (defaulting to OFF) and initializes any I2C/ADC interfaces required for current monitoring.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>[controller]</parametername>
</parameternamelist>
<parameterdescription>
<para>The rail controller</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="note"><para>This function is idempotent. </para>
</simplesect>
</para>
        </detaileddescription>
