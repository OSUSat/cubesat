        <type>bool</type>
        <definition>bool osusat_event_bus_publish</definition>
        <argsstring>(osusat_event_id_t event_id, const void *payload, size_t len)</argsstring>
        <name>osusat_event_bus_publish</name>
        <param>
          <type><ref refid="group__osusat__event__bus__types_1gac1bdf9439b2f075299a2f98e80fe4264" kindref="member">osusat_event_id_t</ref></type>
          <declname>event_id</declname>
        </param>
        <param>
          <type>const void *</type>
          <declname>payload</declname>
        </param>
        <param>
          <type>size_t</type>
          <declname>len</declname>
        </param>
        <briefdescription>
<para>Publish an event to the bus. </para>
        </briefdescription>
        <detaileddescription>
<para>Copies the event data into the queue. Safe to call from ISRs.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">event_id</parametername>
</parameternamelist>
<parameterdescription>
<para>The Composite ID of the event. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">payload</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to data to copy (can be NULL). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">len</parametername>
</parameternamelist>
<parameterdescription>
<para>Length of data (must be &lt;= OSUSAT_EVENT_MAX_PAYLOAD).</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>true</parametername>
</parameternamelist>
<parameterdescription>
<para>Event queued successfully. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>false</parametername>
</parameternamelist>
<parameterdescription>
<para>Queue full (Event Dropped!). </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
